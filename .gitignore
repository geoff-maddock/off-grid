# Dependencies
node_modules/
worker/node_modules/

# Cloudflare Wrangler local state & secrets
.wrangler/
.mf/
.dev.vars
.dev.vars.*
wrangler.toml.bak

# Real Wrangler config holds account-specific IDs — keep it local.
# Commit wrangler.toml.example instead (copy it to wrangler.toml to start).
worker/wrangler.toml

# Local D1 / SQLite databases
*.sqlite
*.sqlite3
*.db

# Your media lives in R2, not git. Ignore everything under mixes/
# (audio, cover art, generated peaks) but keep the folder structure.
mixes/**
!mixes/
!mixes/**/
!mixes/**/.gitkeep

# Stray audio anywhere else
*.mp3
*.wav
*.flac
*.ogg
*.m4a
*.aac

# Environment / secrets
.env
.env.*
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Personal / private working notes — never commit
offline/
.claude/settings.local.json

# Local player-page config (holds your real R2 manifest URL)
config.local.js

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

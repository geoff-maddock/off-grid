# Copy this file to `wrangler.toml` and fill in your own values.
#   cp wrangler.toml.example wrangler.toml
# The real wrangler.toml is gitignored so your account-specific IDs never get committed.

name = "offgrid-api"
main = "src/index.js"
compatibility_date = "2024-12-01"

[[r2_buckets]]
binding = "BUCKET"
bucket_name = "offgrid-media"   # name of the R2 bucket you created

# Run `wrangler d1 create offgrid-db` and paste the returned database_id below.
# If you pick a different database name, also update the db:* scripts in
# package.json — they hardcode `offgrid-db`.
[[d1_databases]]
binding = "DB"
database_name = "offgrid-db"
database_id = "YOUR_DATABASE_ID"

[vars]
# Allowed origin(s) for the admin API. "*" is fine to start. For production,
# lock it down to a comma-separated allowlist of the exact origins your admin is
# served from (scheme + host + port), e.g.:
#   CORS_ORIGIN = "https://your-domain.com,http://localhost:8080"
# The Worker echoes a request's Origin when it matches the list.
CORS_ORIGIN = "*"
# Must match bucket_name above. Used when generating presigned upload URLs.
R2_BUCKET_NAME = "offgrid-media"
# Public base URL of your R2 bucket (r2.dev URL or custom domain), no trailing
# slash. Served to the admin UI via the unauthenticated GET /config endpoint so
# users log in with just email + password instead of typing it in.
R2_PUBLIC_URL = "https://pub-xxxxxxxx.r2.dev"

# Secrets (NOT stored in this file) — set each with `wrangler secret put <NAME>`:
#   ADMIN_TOKEN            — bootstrap/legacy admin token (creates the first user)
#   JWT_SECRET             — random string used to sign login sessions (user accounts)
#   R2_ACCESS_KEY_ID       — R2 API token access key (for presigned uploads)
#   R2_SECRET_ACCESS_KEY   — R2 API token secret
#   CF_ACCOUNT_ID          — your Cloudflare account ID
# Generate JWT_SECRET with e.g.: openssl rand -hex 32
